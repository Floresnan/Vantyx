rt os
import typer
import httpx
from rich import print
from rich.pretty import Pretty

app = typer.Typer(help="Vantyx CLI (vx)")

def api_base() -> str:
    return os.getenv("VANTYX_API", "http://127.0.0.1:8000")

@app.command()
def ping():
    """Testa comunicação com a API."""
    base = api_base()
    try:
        r = httpx.get(f"{base}/health", timeout=5)
        print(f"[green]OK[/green] {base}/health -> {r.status_code}")
        print(Pretty(r.json()))
    except Exception as e:
        print(f"[red]Falha[/red] ao chamar {base}/health")
        print(str(e))
        raise typer.Exit(code=1)

@app.command()
def ops():
    """Mostra o painel do dia (quando o endpoint /ops/daily existir)."""
    base = api_base()
    url = f"{base}/ops/daily"
    try:
        r = httpx.get(url, timeout=10)
        print(f"[cyan]{url}[/cyan] -> {r.status_code}")
        if r.headers.get("content-type", "").startswith("application/json"):
            print(Pretty(r.json()))
        else:
            print(r.text)
    except Exception as e:
        print(f"[red]Falha[/red] ao chamar {url}")
        print(str(e))
        raise typer.Exit(code=1)


@app.command("lead-set")
def lead_set(
    lead_id: str = typer.Argument(..., help="ID (UUID) do lead"),
    etapa: str | None = typer.Option(None, "--etapa", help="Nova etapa"),
    interesse: int | None = typer.Option(None, "--interesse", min=1, max=5, help="Interesse 1..5"),
    urgencia: int | None = typer.Option(None, "--urgencia", min=1, max=5, help="Urgência 1..5"),
    budget: float | None = typer.Option(None, "--budget", help="Valor estimado (opcional)"),
):
    """Atualiza etapa/interesse/urgencia (e budget opcional) de um lead."""
    base = api_base()
    url = f"{base}/leads/{lead_id}"

    payload = {}
    if etapa is not None:
        payload["etapa"] = etapa
    if interesse is not None:
        payload["interesse"] = interesse
    if urgencia is not None:
        payload["urgencia"] = urgencia
    if budget is not None:
        payload["budget"] = budget

    if not payload:
        print("[yellow]Nada para atualizar.[/yellow] Use --etapa/--interesse/--urgencia/--budget")
        raise typer.Exit(code=1)

    r = httpx.patch(url, json=payload, timeout=10)
    print(f"[cyan]{url}[/cyan] -> {r.status_code}")
    if r.headers.get("content-type", "").startswith("application/json"):
        print(Pretty(r.json()))
    else:
        print(r.text)


@app.command("top")
def top(
    min_score: int = typer.Option(10, "--min-score", help="Score mínimo"),
    limit: int = typer.Option(10, "--limit", help="Quantidade"),
    phone_only: bool = typer.Option(True, "--phone-only/--all", help="Somente com telefone"),
):
    """Mostra os melhores leads para agir agora (filtrando o /ops/daily)."""
    base = api_base()
    url = f"{base}/ops/daily"

    try:
        r = httpx.get(url, timeout=10)
        r.raise_for_status()
        data = r.json()
        leads = data.get("top_leads", [])

        def ok(x):
            if phone_only and not x.get("telefone"):
                return False
            return (x.get("score") or 0) >= min_score

        selected = [x for x in leads if ok(x)][:limit]

        print(f"[cyan]{url}[/cyan] -> {r.status_code}")
        print(f"[bold]TOP (min_score={min_score}, phone_only={phone_only}, limit={limit})[/bold]")
        print(Pretty(selected))
    except Exception as e:
        print(f"[red]Falha[/red] ao chamar {url}")
        print(str(e))
        raise typer.Exit(code=1)


@app.command("import-a6")
def import_a6(
    path: str = typer.Argument(..., help="CSV do A6"),
    limit: int = typer.Option(0, "--limit"),
):
    """Importa leads_a6.csv sem duplicar usando meta_leadgen_id determinístico."""
    import csv
    import os
    import hashlib

    base = api_base()
    url = f"{base}/leads/upsert"
    p = os.path.expanduser(path)

    ok = 0
    fail = 0

    def to_int(v):
        if not v:
            return None
        try:
            return int(float(str(v).strip()))
        except:
            return None

    def to_float(v):
        if not v:
            return None
        try:
            s = str(v).strip().replace(".", "").replace(",", ".")
            return float(s)
        except:
            return None

    with open(p, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)

        for i, row in enumerate(reader, start=1):
            if limit and i > limit:
                break

            nome = (row.get("nome") or "").strip() or None
            origem = (row.get("origem") or "").strip() or "a6"
            perfil = (row.get("perfil") or "").strip() or None
            etapa = (row.get("etapa") or "").strip() or None

            interesse = to_int(row.get("interesse"))
            urgencia = to_int(row.get("urgencia"))
            budget = to_float(row.get("budget"))

            ultimo_contato = (row.get("ultimo_contato") or "").strip()
            if not ultimo_contato:
                ultimo_contato = None

            payload = {
                "nome": nome,
                "origem": origem,
                "perfil": perfil,
                "budget": budget,
                "etapa": etapa,
                "interesse": interesse,
                "urgencia": urgencia,
                "ultimo_contato": ultimo_contato,
                "raw": {"a6_csv": row},
            }

            # chave determinística
            key_src = "|".join([
                str(nome or ""),
                str(origem or ""),
                str(perfil or ""),
                str(budget or ""),
                str(etapa or ""),
                str(interesse or ""),
                str(urgencia or ""),
                str(ultimo_contato or ""),
            ])

            payload["meta_leadgen_id"] = "a6:" + hashlib.sha1(
                key_src.encode("utf-8")
            ).hexdigest()

            try:
                r = httpx.post(url, json=payload, timeout=15)
                if r.status_code >= 300:
                    fail += 1
                    print(f"[red]FAIL[/red] linha {i} -> {r.status_code}")
                else:
                    ok += 1
            except Exception as e:
                fail += 1
                print(f"[red]FAIL[/red] linha {i} -> {e}")

    print(f"[green]OK[/green] importados={ok} falhas={fail}")

@app.command("import-a6")
def import_a6(
    path: str = typer.Argument(..., help="CSV do A6 (ex: ~/python-imobiliario/leads_a6.csv)"),
    limit: int = typer.Option(0, "--limit", help="0 = sem limite"),
):
    """Importa leads_a6.csv para o Postgres via /leads/upsert."""
    import csv
    import os
meta_leadgen_id: Optional[str] = None
    base = api_base()
    url = f"{base}/leads/upsert"
    p = os.path.expanduser(path)

    ok = 0
    fail = 0

    with open(p, newline="", encoding="utf-8") as f:
        reader = csv.DictReader(f)
        for i, row in enumerate(reader, start=1):
            if limit and i > limit:
                break

            payload = {
                "raw": {"a6_csv": row},
                "nome": (row.get("nome") or "").strip() or None,
                "origem": (row.get("origem") or "").strip() or "csv",
                "perfil": (row.get("perfil") or "").strip() or None,
                "etapa": (row.get("etapa") or "").strip() or None,
            }

            # números
            def to_int(v):
                if v is None:
                    return None
                s = str(v).strip()
                if s == "":
                    return None
                try:
                    return int(float(s))
                except:
                    return None

            def to_float(v):
                if v is None:
                    return None
                s = str(v).strip()
                if s == "":
                    return None
                try:
                    # aceita "1.234,56" ou "1234.56"
                    s = s.replace(".", "").replace(",", ".")
                    return float(s)
                except:
                    return None

            payload["interesse"] = to_int(row.get("interesse"))
            payload["urgencia"] = to_int(row.get("urgencia"))
            payload["budget"] = to_float(row.get("budget"))

            # data (YYYY-MM-DD ou vazio)
            uc = (row.get("ultimo_contato") or "").strip()
            if uc:
                payload["ultimo_contato"] = uc  # API aceita date no formato ISO

            try:
                r = httpx.post(url, json=payload, timeout=15)
                if r.status_code >= 300:
                    fail += 1
                    print(f"[red]FAIL[/red] linha {i} -> {r.status_code} {r.text}")
                else:
                    ok += 1
            except Exception as e:
                fail += 1
                print(f"[red]FAIL[/red] linha {i} -> {e}")

    print(f"[green]OK[/green] importados={ok} falhas={fail} -> {url}")
